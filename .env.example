# Copy this file to .env and fill in real values.
# .env is gitignored — never commit secrets.

# ---- Server ----
# MongoDB Atlas connection string (mongodb+srv://...)
MONGODB_URI=

# Privy app credentials (https://dashboard.privy.io)
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Optional overrides
# PORT=3000
# CORS_ORIGIN=http://localhost:5173

# ---- Client (Vite) ----
# Same app id as PRIVY_APP_ID — exposed to the browser (it's public by design).
# Must be prefixed with VITE_ for Vite to expose it to client code.
VITE_PRIVY_APP_ID=
